#!/bin/bash
# cbox — enter the agent-sandbox container.
#
# Usage:
#   cbox                  bash shell in /projects
#   cbox <repo>           bash shell in /projects/<repo>
#   cbox -c               claude in /projects
#   cbox -c <repo>        claude in /projects/<repo>

set -e

# Container name — change if you used a different name in bootstrap.sh
CONTAINER="${CLAUDE_SANDBOX_CONTAINER:-claude-box}"

claude_mode=0
if [[ "${1:-}" == "-c" || "${1:-}" == "--claude" ]]; then
  claude_mode=1
  shift
fi
repo="${1:-}"

# Auto-start the container if it's exited.
if ! docker ps --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
  if docker ps -a --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
    echo "${CONTAINER} exists but isn't running — starting..." >&2
    docker start "$CONTAINER" >/dev/null
    sleep 1
  else
    echo "${CONTAINER} does not exist. Run bootstrap.sh first." >&2
    exit 1
  fi
fi

target="/projects"
[[ -n "$repo" ]] && target="/projects/$repo"

if [[ $claude_mode -eq 1 ]]; then
  # --dangerously-skip-permissions: bypass all prompts. Container guard rails
  # (squid allowlist, gh wrapper, pre-commit secret-scan) still enforce.
  exec docker exec -it "$CONTAINER" bash -lc "cd '$target' && exec claude --dangerously-skip-permissions"
else
  exec docker exec -it "$CONTAINER" bash -lc "cd '$target' && exec bash"
fi
