#!/bin/bash
# clip-watcher — WSL-side bridge for the container's clipboard.
# Polls the host-visible clipboard directory (inotify doesn't fire on WSL2
# 9p mounts so we can't use inotifywait here). Dispatches by filename:
#   out      → container wrote outgoing text; pipe to Windows clip.exe
#   request  → container asks for clipboard; capture via PowerShell. An image on the clipboard
#              is saved as response.png; otherwise the text goes to response.
#
# Run as a systemd service (see claude-clip-watcher.service).

set -u
# Host dir backing the container's /projects bind. bootstrap pins this via a systemd drop-in
# (Environment=CLAUDE_CLIPBOARD_DIR=$PROJECTS_HOST_PATH/.claude-clipboard); the default covers
# a manual run with the default projects location.
DIR="${CLAUDE_CLIPBOARD_DIR:-${HOME:-/root}/projects/.claude-clipboard}"
CLIP_EXE="/mnt/c/Windows/System32/clip.exe"
POWERSHELL="/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe"
LOG="/tmp/claude-clip-watcher.log"
POLL_INTERVAL=0.5

mkdir -p "$DIR"
touch "$DIR/out"

# Self-rotate log if huge.
if [[ -f "$LOG" && $(stat -c %s "$LOG") -gt 1048576 ]]; then
  : > "$LOG"
fi

echo "[$(date -Iseconds)] watcher starting (polling), watching $DIR" >> "$LOG"

last_out_mtime=$(stat -c %Y "$DIR/out" 2>/dev/null || echo 0)

while true; do
  sleep "$POLL_INTERVAL"

  # Outbound: container → Windows clipboard
  cur_out_mtime=$(stat -c %Y "$DIR/out" 2>/dev/null || echo 0)
  if [[ "$cur_out_mtime" != "$last_out_mtime" ]]; then
    bytes=$(stat -c %s "$DIR/out" 2>/dev/null || echo 0)
    if [[ "$bytes" -gt 0 ]]; then
      "$CLIP_EXE" < "$DIR/out"
      echo "[$(date -Iseconds)] out → clipboard ($bytes bytes)" >> "$LOG"
    fi
    last_out_mtime=$cur_out_mtime
  fi

  # Inbound: container request → capture Windows clipboard. An image is saved as response.png
  # (Claude reads images from a path); otherwise the text goes to response. The image attempt is
  # best-effort — if there's no image, wslpath is missing, or PowerShell errors, we fall back to text.
  if [[ -e "$DIR/request" ]]; then
    rm -f "$DIR/response" "$DIR/response.png"
    win_png="$(wslpath -w "$DIR/response.png" 2>/dev/null || true)"
    if [[ -n "$win_png" ]]; then
      "$POWERSHELL" -NoProfile -Sta -Command "Add-Type -AssemblyName System.Windows.Forms, System.Drawing; \$i = [System.Windows.Forms.Clipboard]::GetImage(); if (\$i) { \$i.Save('$win_png', [System.Drawing.Imaging.ImageFormat]::Png) }" 2>>"$LOG"
    fi
    if [[ -s "$DIR/response.png" ]]; then
      echo "[$(date -Iseconds)] clipboard → response.png (image)" >> "$LOG"
    else
      rm -f "$DIR/response.png"
      "$POWERSHELL" -NoProfile -Command 'Get-Clipboard -Raw' 2>/dev/null | sed 's/\r$//' > "$DIR/response"
      echo "[$(date -Iseconds)] clipboard → response (text)" >> "$LOG"
    fi
    rm -f "$DIR/request"
  fi
done
