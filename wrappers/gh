#!/usr/bin/env bash
# gh wrapper: blocks destructive operations unless CLAUDE_UNLOCK_DESTRUCTIVE=1.
# Always logs to $CLAUDE_AUDIT_LOG (defaults to /audit/$(date +%F).jsonl).

set -euo pipefail

. "${AGENT_LIB:-/usr/local/bin/agent-lib.sh}"

REAL_GH="${CLAUDE_REAL_GH:-/usr/bin/gh}"
AUDIT_LOG="${CLAUDE_AUDIT_LOG:-/audit/$(date +%F).jsonl}"
CWD="${PWD}"
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

log() {
  local action="$1" blocked="$2" reason="${3:-}"
  mkdir -p "$(dirname "$AUDIT_LOG")"
  printf '{"ts":"%s","src":"gh-wrapper","action":"gh %s","cwd":"%s","blocked":%s,"reason":"%s"}\n' \
    "$TS" "$(json_escape "$action")" "$(json_escape "$CWD")" "$blocked" "$(json_escape "$reason")" >> "$AUDIT_LOG"
}

joined_args="$*"

# --- Normalize argv ---------------------------------------------------------
# Build a normalized token stream so the intent check is argv-aware rather than
# a substring match over the whole command line. Normalization:
#   * --flag=value         -> --flag value
#   * --method             -> -X        (gh long form of -X)
#   * --field / --raw-field -> -f        (gh long forms of -f)
#   * -F                   -> -f
# Original argv is still passed verbatim to the real gh on pass-through.
NORM=()
for arg in "$@"; do
  if [[ "$arg" == --*=* ]]; then
    flag="${arg%%=*}"
    val="${arg#*=}"
    case "$flag" in
      --method)    NORM+=("-X" "$val") ;;
      --field|--raw-field) NORM+=("-f" "$val") ;;
      *)           NORM+=("$flag" "$val") ;;
    esac
  else
    case "$arg" in
      --method)            NORM+=("-X") ;;
      --field|--raw-field|-F) NORM+=("-f") ;;
      *)                   NORM+=("$arg") ;;
    esac
  fi
done

# Positional (non-option) tokens, in order, for subcommand identification.
POS=()
for tok in "${NORM[@]:-}"; do
  [[ -z "$tok" ]] && continue
  [[ "$tok" == -* ]] && continue
  POS+=("$tok")
done

sub1="${POS[0]:-}"
sub2="${POS[1]:-}"

# Does the normalized stream contain `-X <method>` for the given method?
has_method() {
  local want="$1" i
  for ((i = 0; i < ${#NORM[@]}; i++)); do
    if [[ "${NORM[i]}" == "-X" && "${NORM[i+1]:-}" == "$want" ]]; then
      return 0
    fi
  done
  return 1
}

# Does any positional token target a /repos/... API path?
api_targets_repos() {
  local tok
  for tok in "${POS[@]:-}"; do
    [[ "$tok" == /repos/* || "$tok" == repos/* ]] && return 0
  done
  return 1
}

# Does any `-f key=value` (after normalization) set visibility=public/internal?
has_visibility_payload() {
  local i
  for ((i = 0; i < ${#NORM[@]}; i++)); do
    if [[ "${NORM[i]}" == "-f" ]]; then
      case "${NORM[i+1]:-}" in
        visibility=public|visibility=internal) return 0 ;;
      esac
    fi
  done
  return 1
}

# For `repo edit`, is --visibility public|internal requested (any spelling)?
repo_edit_visibility_flip() {
  local i
  for ((i = 0; i < ${#NORM[@]}; i++)); do
    if [[ "${NORM[i]}" == "--visibility" ]]; then
      case "${NORM[i+1]:-}" in
        public|internal) return 0 ;;
      esac
    fi
  done
  return 1
}

# --- Intent check -----------------------------------------------------------
is_blocked=0
reason=""

case "$sub1" in
  repo)
    case "$sub2" in
      delete)   is_blocked=1; reason="repo delete" ;;
      transfer) is_blocked=1; reason="repo transfer" ;;
      archive)  is_blocked=1; reason="repo archive" ;;
      edit)
        if repo_edit_visibility_flip; then
          is_blocked=1; reason="repo edit --visibility public/internal"
        fi
        ;;
    esac
    ;;
  api)
    if has_method PATCH || has_method DELETE; then
      if api_targets_repos; then
        is_blocked=1; reason="api -X PATCH/DELETE /repos/..."
      fi
    fi
    if [[ $is_blocked -eq 0 ]] && has_visibility_payload; then
      is_blocked=1; reason="api visibility=public/internal"
    fi
    ;;
esac

if [[ $is_blocked -eq 1 ]]; then
  if [[ "${CLAUDE_UNLOCK_DESTRUCTIVE:-0}" == "1" ]]; then
    log "$joined_args" "false" "unlock-used:$reason"
    exec "$REAL_GH" "$@"
  else
    log "$joined_args" "true" "$reason"
    cat >&2 <<MSG
BLOCKED: gh $joined_args
  Matched guard rule: $reason
  To proceed: CLAUDE_UNLOCK_DESTRUCTIVE=1 gh $joined_args
MSG
    exit 75
  fi
fi

# Benign — log and pass through.
log "$joined_args" "false" ""
exec "$REAL_GH" "$@"
