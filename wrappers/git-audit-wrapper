#!/usr/bin/env bash
# git-audit-wrapper: log git ops of interest. Called from audit-shell.sh, not a PATH shim.
set -euo pipefail
AUDIT_LOG="${CLAUDE_AUDIT_LOG:-/audit/$(date +%F).jsonl}"
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
CWD="${PWD}"
argv="$*"

case "$argv" in
  "push --force "*|"push --force-with-lease "*|"push -f "*)
    reason="force-push"
    ;;
  "push "*)
    # Detect non-origin pushes.
    remote=$(echo "$argv" | awk '{for(i=2;i<=NF;i++) if($i !~ /^-/) {print $i; exit}}')
    if [[ -n "$remote" && "$remote" != "origin" ]]; then
      reason="non-origin-push:$remote"
    else
      reason=""
    fi
    ;;
  "remote add "*)
    reason="new-remote"
    ;;
  *)
    reason=""
    ;;
esac

if [[ -n "$reason" ]]; then
  mkdir -p "$(dirname "$AUDIT_LOG")"
  printf '{"ts":"%s","src":"git-wrapper","action":"git %s","cwd":"%s","blocked":false,"reason":"%s"}\n' \
    "$TS" "$argv" "$CWD" "$reason" >> "$AUDIT_LOG"
fi
